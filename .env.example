# Copy to .env and fill
XAI_API_KEY=sk-...          # or OPENAI_API_KEY for other providers
# OPENAI_BASE_URL=https://api.x.ai/v1   # for xAI Grok (default in config if key present)
# OPENAI_BASE_URL=http://localhost:1234/v1   # LM Studio / Ollama openai-compat
# OPENAI_API_KEY=not-needed

BRAVE_API_KEY=...           # optional but preferred (free tier sufficient). Get at brave.com/search/api/
MODEL=grok-4.3-latest       # or grok-4.3, local model name, etc.
DB_PATH=market_research.db
TARGET_COMPANY=Harvard BioScience   # This PoC is for ONE company + its subsidiaries
